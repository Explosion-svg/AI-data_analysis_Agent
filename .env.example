# ═══════════════════════════════════════════════════════════════
#  AI Data Analysis Agent — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME="AI Data Analysis Agent"
APP_VERSION="1.0.0"
ENV=dev                  # dev | staging | prod
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=1

# API protection (leave empty to disable auth)
API_KEY=

# ── Database (OLTP) ──────────────────────────────────────────
# SQLite (default, for development)
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agent_db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Data Warehouse (OLAP) ─────────────────────────────────────
# SQLite (default, for development)
WAREHOUSE_URL=sqlite+aiosqlite:///./data/warehouse.db

# ClickHouse example:
# WAREHOUSE_URL=clickhouse+asynch://user:password@localhost:8123/default

# ── Vector Store ──────────────────────────────────────────────
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_DOCS_COLLECTION=docs
CHROMA_SCHEMA_COLLECTION=schema

# ── LLM — OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# ── LLM — DeepSeek (optional) ────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── LLM — Anthropic Claude (optional) ────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── LLM — Local (Ollama / LM Studio, optional) ───────────────
LOCAL_LLM_API_BASE=
LOCAL_LLM_MODEL=

# ── LLM Common ───────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60.0
LLM_MAX_RETRIES=3

# ── Embedding ─────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Reliability ───────────────────────────────────────────────
SQL_QUERY_TIMEOUT=30.0
PYTHON_EXEC_TIMEOUT=20.0
AGENT_MAX_ITERATIONS=10
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60.0
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=30.0

# ── Memory / Cache ────────────────────────────────────────────
CONVERSATION_MAX_TURNS=20
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=256

# ── Observability ─────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=true
ENABLE_TRACING=false
OTLP_ENDPOINT=               # e.g. http://jaeger:4317
ENABLE_METRICS=true
METRICS_PORT=9090

# ── Security ──────────────────────────────────────────────────
SQL_READONLY=true            # Only allow SELECT statements
PYTHON_SANDBOX=true          # Sandbox Python execution
